generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Dashboard {
  id          String   @id @default(uuid())
  title       String
  description String?
  url         String
  position    Int      @unique
  iconKey     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model IconIndex {
  id        String   @id @default(uuid())
  name      String
  path      String   @unique
  createdAt DateTime @default(now())
}